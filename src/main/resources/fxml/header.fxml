<?import cn.oyzh.fx.gui.svg.glyph.layout.Layout2SVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.QuitSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.SettingSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.ToolsSVGGlyph?>
<?import cn.oyzh.fx.gui.svg.glyph.TransportSVGGlyph?>
<?import cn.oyzh.fx.plus.controls.box.FXHBox?>
<?import cn.oyzh.fx.plus.controls.FXHeaderBar?>
<?import cn.oyzh.fx.plus.controls.pane.FXPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import cn.oyzh.fx.gui.svg.pane.LayoutSVGPane?>
<?import cn.oyzh.fx.gui.svg.label.TransportSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.ToolsSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.SettingSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.QuitSVGLabel?>
<?import cn.oyzh.fx.gui.svg.label.AboutSVGLabel?>
<FXHeaderBar xmlns:fx="http://javafx.com/fxml/1" fx:controller="cn.oyzh.easymongo.controller.HeaderController"
             prefHeight="30">
    <content>
        <FXHBox prefHeight="30">
            <LayoutSVGPane fx:id="layoutPane" onMousePrimaryClicked="#layout" >
                <FXHBox.margin>
                    <Insets left="10" top="9"/>
                </FXHBox.margin>
            </LayoutSVGPane>
            <TransportSVGLabel onMousePrimaryClicked="#transport" size="12">
                <FXHBox.margin>
                    <Insets left="10" top="7"/>
                </FXHBox.margin>
            </TransportSVGLabel>
            <ToolsSVGLabel onMousePrimaryClicked="#tool">
                <FXHBox.margin>
                    <Insets left="10" top="7"/>
                </FXHBox.margin>
            </ToolsSVGLabel>
            <AboutSVGLabel onMousePrimaryClicked="#about">
                <FXHBox.margin>
                    <Insets left="10" top="7"/>
                </FXHBox.margin>
            </AboutSVGLabel>
            <QuitSVGLabel onMousePrimaryClicked="#quit">
                <FXHBox.margin>
                    <Insets left="10" top="7"/>
                </FXHBox.margin>
            </QuitSVGLabel>
            <SettingSVGLabel onMousePrimaryClicked="#setting">
                <FXHBox.margin>
                    <Insets left="10" top="7"/>
                </FXHBox.margin>
            </SettingSVGLabel>
        </FXHBox>
    </content>
</FXHeaderBar>
